# 应用配置模板。
# 本地开发时复制为 app-config/app.yaml，并填入非敏感配置。
# 本文件只放模型名、提供方、超时、开关、数据库地址等非敏感值，后续可按配置映射管理。

# 运行时开关和本地前端地址。
runtime:
  # 调试开关：true 时会输出 OCR 页摘要、旋转方向、模型解析元数据等诊断信息。
  debug: false
  # Web 控制台访问地址；企业微信登录完成后会跳转到该地址。
  web_console_base_url: https://your-domain.com

# OpenAI 兼容接口配置；密钥放在 .env 的 OPENAI_API_KEY。
openai:
  # OpenAI 兼容接口地址。
  base_url: https://your-openai-compatible-api/v1

# 营业执照审核相关配置。
business_license:
  vision:
    # 文件识别提供方：aliyun、qwen_ocr、qwen_ocr_with_aliyun_fallback。
    provider: qwen_ocr_with_aliyun_fallback
  qwen_ocr:
    # Qwen OCR 多模态模型名。
    model: qwen-vl-max
  # Skill 规则审核模型名。
  skill_review_model: qwen-plus

# 阿里云云市场 OCR 配置；AppCode 放在 .env 的 ALIYUN_OCR_APPCODE。
aliyun_ocr:
  # 阿里云 OCR 接口地址。
  api_url: https://gjbsb.market.alicloudapi.com/ocrservice/advanced
  # 请求体中图片字段名。
  image_field: img
  # 阿里云 OCR 返回文本后，用这个模型把 OCR 文本解析成结构化字段。
  llm_parse_model: qwen-plus
  # 阿里云 OCR 请求体附加参数。
  body_options: {}
  # 本地预筛提供方；例如 rapidocr，为空则关闭。
  local_prefilter_provider: rapidocr
  # PDF 页方向不正时是否尝试旋转候选方向。
  try_rotations: true
  # 找到营业执照页后是否停止处理后续页。
  stop_after_first_license: true
  # OCR 旋转候选顺序。
  rotation_order:
    - 270
    - 0
    - 90
    - 180

# SRM 来源数据库地址；账号和密码放在 .env。
srm_mysql:
  host: your-srm-mysql-host
  port: 3306
  database: srm

# 审核结果数据库地址；账号和密码放在 .env。
review_result_mysql:
  host: your-review-mysql-host
  port: 3306
  database: document_ai_review

# StarRocks 批次报告验证库；账号和密码放在 .env。
starrocks:
  host: your-starrocks-host
  port: 9030
  database: work_temp

# Web 控制台本地认证配置；密码和签名密钥放在 .env。
web_console_auth:
  username: reviewer

# 企业微信登录和通知路由配置；密钥和 worker 令牌放在 .env。
wecom:
  corp_id: your-corp-id
  agent_id: your-agent-id
  # 企业微信通知里的审核详情基础地址。
  notification_base_url: https://your-domain.com
