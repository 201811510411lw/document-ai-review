# 本地敏感配置。不要提交真实密钥。
# 复制此文件为 .env 并填入真实值。
# 非敏感运行配置请放在 app-config/app.yaml。


# -----------------------------------------------------------------------------
# 模型和 OCR 凭据
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
ALIYUN_OCR_APPCODE=your-aliyun-ocr-appcode


# -----------------------------------------------------------------------------
# SRM 来源数据库账号
# -----------------------------------------------------------------------------
SRM_MYSQL_HOST=your-srm-mysql-host
SRM_MYSQL_PORT=3306
SRM_MYSQL_DATABASE=srm
SRM_MYSQL_USER=your-srm-user
SRM_MYSQL_PASSWORD=your-srm-password


# -----------------------------------------------------------------------------
# 审核结果数据库账号
# -----------------------------------------------------------------------------
REVIEW_RESULT_MYSQL_HOST=your-review-mysql-host
REVIEW_RESULT_MYSQL_PORT=3306
REVIEW_RESULT_MYSQL_DATABASE=document_ai_review
REVIEW_RESULT_MYSQL_USER=your-review-user
REVIEW_RESULT_MYSQL_PASSWORD=your-review-password


# -----------------------------------------------------------------------------
# 控制台本地登录和令牌签名
# -----------------------------------------------------------------------------
WEB_CONSOLE_AUTH_USERNAME=reviewer
WEB_CONSOLE_AUTH_PASSWORD=your-password
WEB_CONSOLE_AUTH_SECRET=your-secret-key
WEB_CONSOLE_AUTH_TOKEN_TTL_SECONDS=86400


# -----------------------------------------------------------------------------
# 企业微信应用密钥
# -----------------------------------------------------------------------------
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id
WECOM_SECRET=your-wecom-secret
WECOM_WORKER_TOKEN=your-worker-token
