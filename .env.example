# 敏感配置模板。
# 本地开发时复制为 .env，并填入真实密钥、密码和令牌。
# 非敏感运行配置请放在 app-config/app.yaml。


# -----------------------------------------------------------------------------
# 1. 模型和 OCR 凭据
# -----------------------------------------------------------------------------

OPENAI_API_KEY=<required>
# 历史兼容字段；新配置优先使用 OPENAI_API_KEY。
OPENAI_API_KEY1=
ALIYUN_OCR_APPCODE=<required>


# -----------------------------------------------------------------------------
# 2. SRM 来源数据库账号
# -----------------------------------------------------------------------------

SRM_MYSQL_USER=<required>
SRM_MYSQL_PASSWORD=<required>


# -----------------------------------------------------------------------------
# 3. 审核结果数据库账号
# -----------------------------------------------------------------------------

REVIEW_RESULT_MYSQL_USER=<required>
REVIEW_RESULT_MYSQL_PASSWORD=<required>


# -----------------------------------------------------------------------------
# 4. 控制台本地登录和令牌签名
# -----------------------------------------------------------------------------

WEB_CONSOLE_AUTH_PASSWORD=<required>
WEB_CONSOLE_AUTH_SECRET=<required>


# -----------------------------------------------------------------------------
# 5. 企业微信应用密钥
# -----------------------------------------------------------------------------

WECOM_SECRET=<required>
WECOM_WORKER_TOKEN=<required>
