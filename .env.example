# ============================================================
# 企业微信证照机器人 — 环境变量模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ============================================================

# --- Mimo API Key（证照识别用）---
MIMO_API_KEY=sk-你的mimo-key

# --- 企业微信自建应用凭证 ---
WECOM_CORP_ID=你的企业ID
WECOM_AGENT_ID=自建应用的AgentId
WECOM_SECRET=自建应用的Secret
WECOM_TOKEN=回调配置的Token
WECOM_ENCODING_AES_KEY=回调配置的EncodingAESKey

# --- 推送目标（可选，留空=推送给全部）---
NOTIFY_USERS=
NOTIFY_CHAT=

# --- 效期检查 ---
EXPIRY_WARNING_DAYS=30
CHECK_HOUR=9
CHECK_MINUTE=0

# --- Web 服务 ---
CERT_BOT_HOST=0.0.0.0
CERT_BOT_PORT=8000
